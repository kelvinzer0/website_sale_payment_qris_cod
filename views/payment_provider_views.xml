<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend payment.provider form untuk tambah config QRIS & COD -->
    <record id="payment_provider_form_qris_cod" model="ir.ui.view">
        <field name="name">payment.provider.form.qris.cod</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="code" invisible="1"/>
                <group string="QRIS Dinamis Configuration"
                       invisible="code != 'qris_dinamis'">
                    <field name="qris_base_string"
                           placeholder="00020101021126570011ID.DANA.WWW..."
                           widget="text"/>
                    <field name="qris_expiry_minutes"/>
                </group>
                <group string="COD Configuration"
                       invisible="code != 'cod'">
                    <field name="cod_instructions"
                           placeholder="Instruksi untuk customer..."/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
