<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings: tambah section QRIS Dinamis & COD -->
    <record id="res_config_settings_view_form_qris_cod" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.qris.cod</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="QRIS Dinamis &amp; COD" string="QRIS Dinamis &amp; COD" name="website_sale_payment_qris_cod">
                    <block title="QRIS Dinamis Configuration" name="qris_dinamis_config">
                        <setting id="qris_base_string_setting" string="Base QRIS String">
                            <field name="qris_base_string" placeholder="00020101021126570011ID.DANA.WWW..."/>
                        </setting>
                        <setting id="qris_expiry_setting" string="QRIS Expiry (minutes)">
                            <field name="qris_expiry_minutes"/>
                        </setting>
                    </block>
                    <block title="COD Configuration" name="cod_config">
                        <setting id="cod_instructions_setting" string="COD Instructions">
                            <field name="cod_instructions"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
