<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend sale.order form: tambah QRIS info -->
    <record id="sale_order_form_qris_cod" model="ir.ui.view">
        <field name="name">sale.order.form.qris.cod</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="QRIS / COD Payment Info"
                       invisible="not payment_method_code">
                    <field name="payment_method_code" readonly="1"/>
                    <field name="qris_amount" readonly="1"
                           invisible="payment_method_code != 'qris_dinamis'"/>
                    <field name="qris_state" readonly="1"
                           invisible="payment_method_code != 'qris_dinamis'"/>
                    <field name="cod_state" readonly="1"
                           invisible="payment_method_code != 'cod'"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Extend sale.order tree: tambah kolom QRIS/COD state -->
    <record id="sale_order_tree_qris_cod" model="ir.ui.view">
        <field name="name">sale.order.tree.qris.cod</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="payment_method_code" optional="hide"/>
                <field name="qris_state" optional="hide"/>
                <field name="cod_state" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
