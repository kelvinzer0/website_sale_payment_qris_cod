<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: NO-OP sejak v17.0.2.1.0 (QRIS tidak punya expiry lagi).
             Dipertahankan sebagai record untuk backward compatibility, di-disable (active=False). -->
        <record id="cron_expire_qris_transactions" model="ir.cron">
            <field name="name">QRIS: Expire Pending Transactions (DISABLED - no expiry)</field>
            <field name="model_id" ref="model_payment_transaction"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_qris_transactions()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
